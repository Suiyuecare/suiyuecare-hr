generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  suspended
}

enum EmploymentStatus {
  active
  terminated
  on_leave
}

enum RoleKey {
  owner
  hr_admin
  manager
  employee
}

enum AuditAction {
  create
  update
  delete
  publish
  approve
  reject
  login
  role_switch
}

enum PunchSource {
  web
  mobile
  manual
}

enum ClockEventType {
  clock_in
  clock_out
}

enum RequestStatus {
  pending
  approved
  rejected
}

enum ApprovalRequestType {
  leave
  overtime
  punch_correction
  custom_form
}

enum NotificationStatus {
  unread
  read
}

enum PayrollRunStatus {
  draft
  calculated
  blocked
  confirmed
  locked
  released
}

enum PayrollItemKind {
  earning
  allowance
  overtime
  deduction
  employer_contribution
}

model Tenant {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  status       TenantStatus        @default(active)
  plan         String              @default("demo")
  companies    Company[]
  users        User[]
  roles        Role[]
  auditLogs    AuditLog[]
  subscription TenantSubscription?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Company {
  id                            String                                @id @default(cuid())
  tenantId                      String
  tenant                        Tenant                                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                          String
  legalName                     String
  taxId                         String
  timezone                      String                                @default("Asia/Taipei")
  currency                      String                                @default("TWD")
  departments                   Department[]
  jobLevels                     JobLevel[]
  jobPositions                  JobPosition[]
  employees                     Employee[]
  employeeLifecycleEvents       EmployeeLifecycleEvent[]
  employeeOffboardingTasks      EmployeeOffboardingTask[]
  employeeDocuments             EmployeeDocument[]
  employeeEmploymentTerms       EmployeeEmploymentTerm[]
  employeeLaborRosterProfiles   EmployeeLaborRosterProfile[]
  privacySetting                CompanyPrivacySetting?
  employeePrivacyConsents       EmployeePrivacyConsent[]
  dataSubjectRequests           DataSubjectRequest[]
  workRules                     CompanyWorkRule[]
  workRuleAcknowledgements      EmployeeWorkRuleAcknowledgement[]
  trainingSetting               CompanyTrainingSetting?
  trainingCourses               TrainingCourse[]
  trainingAssignments           EmployeeTrainingAssignment[]
  incidentSetting               CompanyIncidentSetting?
  workplaceIncidents            WorkplaceIncident[]
  securitySettings              CompanySecuritySetting?
  fileStorageSettings           CompanyFileStorageSetting?
  operationalResilienceSetting  CompanyOperationalResilienceSetting?
  auditLogs                     AuditLog[]
  auditEvidencePackages         AuditEvidencePackage[]
  shiftTemplates                ShiftTemplate[]
  workSchedules                 WorkSchedule[]
  calendarDays                  CompanyCalendarDay[]
  calendarReviews               CompanyCalendarReview[]
  attendancePolicies            AttendancePolicy[]
  worktimeAgreementSetting      CompanyWorktimeAgreementSetting?
  attendanceRecords             AttendanceRecord[]
  attendancePeriodSignoffs      AttendancePeriodSignoff[]
  clockEvents                   ClockEvent[]
  attendanceExceptions          AttendanceException[]
  leavePolicies                 LeavePolicy[]
  leaveBalances                 LeaveBalance[]
  annualLeaveSettlements        AnnualLeaveSettlement[]
  leaveRequests                 LeaveRequest[]
  overtimeRequests              OvertimeRequest[]
  punchCorrectionRequests       PunchCorrectionRequest[]
  approvalTasks                 ApprovalTask[]
  approvalEvents                ApprovalEvent[]
  notifications                 Notification[]
  notificationSettings          CompanyNotificationSetting?
  notificationDeliveries        NotificationDelivery[]
  announcements                 CompanyAnnouncement[]
  announcementReceipts          EmployeeAnnouncementReceipt[]
  salaryProfiles                SalaryProfile[]
  payrollComplianceProfiles     PayrollComplianceProfile[]
  statutoryInsuranceRecords     StatutoryInsuranceRecord[]
  paymentProfiles               EmployeePaymentProfile[]
  payrollPaymentSecuritySetting CompanyPayrollPaymentSecuritySetting?
  payrollAccountingSettings     CompanyPayrollAccountingSetting?
  payrollRecordkeepingSetting   CompanyPayrollRecordkeepingSetting?
  payrollRuns                   PayrollRun[]
  payrollItems                  PayrollItem[]
  payrollAdjustments            PayrollAdjustment[]
  payrollExports                PayrollExport[]
  payslips                      Payslip[]
  formTemplates                 FormTemplate[]
  workflowTemplateSteps         WorkflowTemplateStep[]
  formSubmissions               FormSubmission[]
  supportAccessGrants           SupportAccessGrant[]
  policyDocuments               CompanyPolicyDocument[]
  aiUsageLogs                   AiUsageLog[]
  productTelemetryEvents        ProductTelemetryEvent[]
  betaPilotTrialRuns            BetaPilotTrialRun[]
  betaPilotTrialEvents          BetaPilotTrialEvent[]
  createdAt                     DateTime                              @default(now())
  updatedAt                     DateTime                              @updatedAt

  @@index([tenantId])
}

model Department {
  id                 String        @id @default(cuid())
  tenantId           String
  companyId          String
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentDepartmentId String?
  parentDepartment   Department?   @relation("DepartmentTree", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[]  @relation("DepartmentTree")
  name               String
  code               String
  jobPositions       JobPosition[]
  employees          Employee[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([companyId, code])
  @@index([tenantId, companyId])
}

model JobLevel {
  id          String        @id @default(cuid())
  tenantId    String
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  rank        Int
  status      String        @default("active")
  description String?
  positions   JobPosition[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([companyId, code])
  @@index([tenantId, companyId])
  @@index([tenantId, companyId, status])
}

model JobPosition {
  id           String      @id @default(cuid())
  tenantId     String
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  levelId      String?
  level        JobLevel?   @relation(fields: [levelId], references: [id], onDelete: SetNull)
  code         String
  title        String
  family       String      @default("general")
  status       String      @default("active")
  description  String?
  employees    Employee[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([companyId, code])
  @@index([tenantId, companyId])
  @@index([tenantId, companyId, status])
  @@index([departmentId])
  @@index([levelId])
}

model CompanySecuritySetting {
  id                      String   @id @default(cuid())
  tenantId                String
  companyId               String   @unique
  company                 Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mfaRequiredForAdmins    Boolean  @default(true)
  mfaRequiredForEmployees Boolean  @default(false)
  ssoEnabled              Boolean  @default(false)
  ssoProvider             String?
  ssoIssuerUrl            String?
  ssoClientId             String?
  ssoJwksUrl              String?
  passwordMinLength       Int      @default(12)
  passwordRequiresNumber  Boolean  @default(true)
  passwordRequiresSymbol  Boolean  @default(true)
  sessionTimeoutMinutes   Int      @default(480)
  idleTimeoutMinutes      Int      @default(60)
  allowedEmailDomainsJson Json
  updatedByUserId         String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenantId, companyId])
}

model User {
  id                 String                 @id @default(cuid())
  tenantId           String
  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email              String
  displayName        String
  status             String                 @default("active")
  employee           Employee?
  userRoles          UserRole[]
  externalIdentities UserExternalIdentity[]
  auditLogs          AuditLog[]             @relation("ActorAuditLogs")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

model UserExternalIdentity {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String
  issuer      String
  subject     String
  emailAtLink String?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, issuer, subject])
  @@index([tenantId, userId])
}

model Role {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         RoleKey
  name        String
  description String
  userRoles   UserRole[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, key])
}

model UserRole {
  id        String   @id @default(cuid())
  tenantId  String
  companyId String
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeType String   @default("company")
  scopeId   String?
  createdAt DateTime @default(now())

  @@unique([companyId, userId, roleId])
  @@index([tenantId, companyId])
}

model TenantSubscription {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                  String    @default("demo")
  status                String    @default("trial")
  seatLimit             Int       @default(10)
  activeSeatCount       Int       @default(0)
  trialEndsAt           DateTime?
  contractStartsAt      DateTime?
  contractEndsAt        DateTime?
  renewalNoticeDays     Int       @default(30)
  billingContactEmail   String?
  contractRef           String?
  contractHash          String?
  paymentCollectionMode String    @default("manual_invoice")
  verificationStatus    String    @default("unverified")
  lastReviewedAt        DateTime?
  updatedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, plan])
  @@index([tenantId, contractEndsAt])
}

model BetaPilotTrialRun {
  id                      String                @id @default(cuid())
  tenantId                String
  companyId               String
  company                 Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status                  String                @default("planned")
  targetEmployeeMin       Int                   @default(20)
  targetEmployeeMax       Int                   @default(50)
  expectedEmployeeCount   Int
  managerCount            Int
  startsAt                DateTime
  endsAt                  DateTime
  startedAt               DateTime?
  completedAt             DateTime?
  completedByUserId       String?
  latestReadinessStatus   String                @default("not_started")
  openBlockedCount        Int                   @default(0)
  openActionRequiredCount Int                   @default(0)
  evidenceSummaryHash     String?
  notesHash               String?
  createdByUserId         String?
  events                  BetaPilotTrialEvent[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, startsAt])
  @@index([tenantId, companyId, endsAt])
}

model BetaPilotTrialEvent {
  id              String            @id @default(cuid())
  tenantId        String
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trialRunId      String
  trialRun        BetaPilotTrialRun @relation(fields: [trialRunId], references: [id], onDelete: Cascade)
  eventType       String
  checkpointId    String?
  status          String
  dayNumber       Int?
  eventAt         DateTime          @default(now())
  evidenceRefHash String?
  summaryHash     String?
  metadataJson    Json
  createdByUserId String?
  createdAt       DateTime          @default(now())

  @@index([tenantId, companyId, trialRunId])
  @@index([tenantId, companyId, checkpointId])
  @@index([tenantId, companyId, eventType])
  @@index([tenantId, companyId, eventAt])
}

model Employee {
  id                        String                            @id @default(cuid())
  tenantId                  String
  companyId                 String
  company                   Company                           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId                    String?                           @unique
  user                      User?                             @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId              String?
  department                Department?                       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPositionId             String?
  jobPosition               JobPosition?                      @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  managerId                 String?
  manager                   Employee?                         @relation("ManagerReports", fields: [managerId], references: [id])
  directReports             Employee[]                        @relation("ManagerReports")
  employeeNo                String
  displayName               String
  jobTitle                  String
  employmentStatus          EmploymentStatus                  @default(active)
  hireDate                  DateTime
  auditLogs                 AuditLog[]                        @relation("ActorEmployeeAuditLogs")
  workSchedules             WorkSchedule[]
  attendanceRecords         AttendanceRecord[]
  attendancePeriodSignoffs  AttendancePeriodSignoff[]
  clockEvents               ClockEvent[]
  attendanceExceptions      AttendanceException[]
  leaveBalances             LeaveBalance[]
  annualLeaveSettlements    AnnualLeaveSettlement[]
  leaveRequests             LeaveRequest[]
  overtimeRequests          OvertimeRequest[]
  punchCorrectionRequests   PunchCorrectionRequest[]
  approvalTasks             ApprovalTask[]                    @relation("ApprovalApprover")
  approvalEvents            ApprovalEvent[]                   @relation("ApprovalActor")
  salaryProfiles            SalaryProfile[]
  payrollComplianceProfiles PayrollComplianceProfile[]
  statutoryInsuranceRecords StatutoryInsuranceRecord[]
  paymentProfiles           EmployeePaymentProfile[]
  payrollItems              PayrollItem[]
  payrollAdjustments        PayrollAdjustment[]
  payslips                  Payslip[]
  formSubmissions           FormSubmission[]
  lifecycleEvents           EmployeeLifecycleEvent[]
  offboardingTasks          EmployeeOffboardingTask[]
  documents                 EmployeeDocument[]
  employmentTerms           EmployeeEmploymentTerm[]
  laborRosterProfile        EmployeeLaborRosterProfile?
  privacyConsents           EmployeePrivacyConsent[]
  dataSubjectRequests       DataSubjectRequest[]
  workRuleAcknowledgements  EmployeeWorkRuleAcknowledgement[]
  trainingAssignments       EmployeeTrainingAssignment[]
  workplaceIncidents        WorkplaceIncident[]
  announcementReceipts      EmployeeAnnouncementReceipt[]
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt

  @@unique([companyId, employeeNo])
  @@index([tenantId, companyId])
  @@index([departmentId])
  @@index([jobPositionId])
  @@index([managerId])
}

model EmployeeLifecycleEvent {
  id                   String                    @id @default(cuid())
  tenantId             String
  companyId            String
  company              Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  eventType            String
  effectiveDate        DateTime
  reason               String
  previousDepartmentId String?
  nextDepartmentId     String?
  previousJobTitle     String?
  nextJobTitle         String?
  previousStatus       EmploymentStatus?
  nextStatus           EmploymentStatus?
  metadataJson         Json
  offboardingTasks     EmployeeOffboardingTask[]
  createdByUserId      String?
  createdAt            DateTime                  @default(now())

  @@index([tenantId, companyId, employeeId])
  @@index([tenantId, companyId, eventType])
  @@index([tenantId, companyId, effectiveDate])
}

model EmployeeOffboardingTask {
  id               String                 @id @default(cuid())
  tenantId         String
  companyId        String
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  lifecycleEventId String
  lifecycleEvent   EmployeeLifecycleEvent @relation(fields: [lifecycleEventId], references: [id], onDelete: Cascade)
  taskType         String
  status           String                 @default("pending")
  dueDate          DateTime
  completedAt      DateTime?
  evidenceRef      String?
  evidenceHash     String?
  notesHash        String?
  updatedByUserId  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([companyId, lifecycleEventId, taskType])
  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, dueDate])
  @@index([tenantId, companyId, employeeId])
}

model EmployeeDocument {
  id                    String    @id @default(cuid())
  tenantId              String
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category              String
  title                 String
  fileName              String
  mimeType              String
  fileSizeBytes         Int
  storageKey            String
  storageProvider       String    @default("demo_object_storage")
  storageBucket         String?
  objectKey             String    @default("")
  checksumSha256        String?
  malwareScanStatus     String    @default("pending")
  encryptionMode        String    @default("provider_managed")
  retentionUntil        DateTime?
  downloadAuditRequired Boolean   @default(true)
  status                String    @default("active")
  visibleToEmployee     Boolean   @default(false)
  expiresAt             DateTime?
  uploadedByUserId      String?
  uploadedAt            DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, companyId, employeeId])
  @@index([tenantId, companyId, category])
  @@index([tenantId, companyId, status])
}

model EmployeeEmploymentTerm {
  id                                      String    @id @default(cuid())
  tenantId                                String
  companyId                               String
  company                                 Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId                              String
  employee                                Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  version                                 String
  status                                  String    @default("draft")
  effectiveFrom                           DateTime
  jobTitle                                String
  workLocation                            String
  regularWorkSchedule                     String
  wagePaymentDay                          String
  wageBasisSummaryHash                    String
  benefitsSummary                         String
  contractLifecycleSummaryHash            String?
  severancePensionBonusSummaryHash        String?
  mealLodgingToolCostSummaryHash          String?
  safetyHealthSummaryHash                 String?
  trainingSummaryHash                     String?
  disasterCompensationSicknessSummaryHash String?
  disciplineSummaryHash                   String?
  rewardDisciplineSummaryHash             String?
  rightsObligationsSummaryHash            String?
  sourceRef                               String?
  acknowledgementRequired                 Boolean   @default(true)
  acknowledgementHash                     String?
  acknowledgedAt                          DateTime?
  createdByUserId                         String?
  updatedByUserId                         String?
  createdAt                               DateTime  @default(now())
  updatedAt                               DateTime  @updatedAt

  @@unique([employeeId, version])
  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, employeeId])
  @@index([tenantId, companyId, acknowledgedAt])
}

model EmployeeLaborRosterProfile {
  id                           String    @id @default(cuid())
  tenantId                     String
  companyId                    String
  company                      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId                   String    @unique
  employee                     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status                       String    @default("incomplete")
  legalNameHash                String?
  nationalIdHash               String?
  birthDate                    DateTime?
  gender                       String?
  nationality                  String?
  hometown                     String?
  registeredAddressHash        String?
  emergencyContactHash         String?
  educationSummary             String?
  workExperienceSummary        String?
  wageInfoHash                 String?
  laborInsuranceEnrollmentDate DateTime?
  rewardDisciplineSummaryHash  String?
  injurySicknessSummaryHash    String?
  otherNecessaryItemsHash      String?
  rosterSourceRef              String?
  requiredFieldsJson           Json
  missingFieldsJson            Json
  verificationStatus           String    @default("unverified")
  lastReviewedAt               DateTime?
  reviewedByUserId             String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, verificationStatus])
  @@index([tenantId, companyId, employeeId])
}

model CompanyFileStorageSetting {
  id                      String    @id @default(cuid())
  tenantId                String
  companyId               String    @unique
  company                 Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider                String
  bucketName              String
  region                  String?
  basePrefix              String
  kmsKeyRef               String?
  malwareScanningRequired Boolean   @default(true)
  signedUrlTtlMinutes     Int       @default(10)
  maxFileSizeMb           Int       @default(25)
  allowedMimeTypesJson    Json
  retentionDays           Int       @default(2555)
  verificationStatus      String    @default("unverified")
  lastVerifiedAt          DateTime?
  verificationNote        String?
  updatedByUserId         String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([tenantId, companyId])
}

model CompanyPrivacySetting {
  id                              String    @id @default(cuid())
  tenantId                        String
  companyId                       String    @unique
  company                         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consentVersion                  String    @default("2026.01")
  consentTitle                    String
  consentBody                     String
  collectionPurpose               String
  requiresEmployeeAcknowledgement Boolean   @default(true)
  dataRetentionYears              Int       @default(7)
  dataSubjectRequestResponseDays  Int       @default(30)
  deletionReviewRequired          Boolean   @default(true)
  crossBorderTransferEnabled      Boolean   @default(false)
  subprocessorsJson               Json
  verificationStatus              String    @default("unverified")
  lastReviewedAt                  DateTime?
  updatedByUserId                 String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  @@index([tenantId, companyId])
  @@index([tenantId, companyId, verificationStatus])
}

model EmployeePrivacyConsent {
  id               String   @id @default(cuid())
  tenantId         String
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  consentVersion   String
  consentTitle     String
  policyHash       String
  source           String   @default("self_service")
  acceptedByUserId String?
  acceptedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([employeeId, consentVersion])
  @@index([tenantId, companyId, consentVersion])
  @@index([tenantId, companyId, employeeId])
}

model DataSubjectRequest {
  id                String    @id @default(cuid())
  tenantId          String
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestType       String
  status            String    @default("submitted")
  summary           String
  resolutionNote    String?
  requestedByUserId String?
  assignedToUserId  String?
  dueAt             DateTime
  completedAt       DateTime?
  metadataJson      Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, employeeId])
  @@index([tenantId, companyId, dueAt])
}

model CompanyTrainingSetting {
  id                         String    @id @default(cuid())
  tenantId                   String
  companyId                  String    @unique
  company                    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  onboardingTrainingRequired Boolean   @default(true)
  targetCompletionDays       Int       @default(7)
  maxFirstWeekMinutes        Int       @default(10)
  autoAssignNewHires         Boolean   @default(true)
  verificationStatus         String    @default("unverified")
  lastReviewedAt             DateTime?
  updatedByUserId            String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([tenantId, companyId])
  @@index([tenantId, companyId, verificationStatus])
}

model TrainingCourse {
  id                    String                       @id @default(cuid())
  tenantId              String
  companyId             String
  company               Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title                 String
  category              String
  description           String
  version               String                       @default("v1")
  status                String                       @default("active")
  requiredForOnboarding Boolean                      @default(true)
  estimatedMinutes      Int                          @default(5)
  sourceRef             String?
  publishedAt           DateTime?
  createdByUserId       String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  assignments           EmployeeTrainingAssignment[]

  @@index([tenantId, companyId, status])
  @@index([tenantId, companyId, requiredForOnboarding])
}

model EmployeeTrainingAssignment {
  id                  String         @id @default(cuid())
  tenantId            String
  companyId           String
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId          String
  employee            Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  courseId            String
  course              TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status              String         @default("assigned")
  dueAt               DateTime
  completedAt         DateTime?
  acknowledgementHash String?
  assignedByUserId    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

